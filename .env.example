# Database settings for PostgreSQL and backend SQLAlchemy async engine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=base_db
DATABASE_URL=postgresql+asyncpg://postgres:123456@db:5432/base_db


# FastAPI backend security key for POST /etf/update header authorization
BOT_API_KEY=super-secret-key


# Telegram bot token from BotFather
BOT_TOKEN=put_your_telegram_bot_token_here


# Telegram username that is auto-seeded into allowed_users on backend startup
ALLOWED_USERNAME=@vlados7529


# Base URL for MOEX ISS API (optional)
MOEX_BASE_URL=https://iss.moex.com/iss


# Backend URL used by tg_client
BACKEND_URL=http://host.docker.internal:3002


# Optional API key used by tg_client as X-API-Key header
API_KEY=super-secret-key
